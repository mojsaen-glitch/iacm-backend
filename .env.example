# Application
APP_NAME="IACM - Iraqi Airways Crew Management"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALLOWED_HOSTS=["http://localhost:3000","http://localhost:8080"]

# Database
DATABASE_URL=postgresql+asyncpg://iacm_user:iacm_password@localhost:5432/iacm_db
DATABASE_URL_SYNC=postgresql://iacm_user:iacm_password@localhost:5432/iacm_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]
ALLOWED_DOC_TYPES=["application/pdf","image/jpeg","image/png"]

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@iraqiairways.iq
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@iraqiairways.iq

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# FTL Limits (EASA defaults - configurable per company)
MAX_MONTHLY_HOURS=100
MAX_YEARLY_HOURS=900
MIN_REST_HOURS=10
MAX_DUTY_HOURS=14

# ─────────────────────────────────────────────────────────────────────────────
# IACM Backend — environment template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control (it is already in .gitignore).
# Rotate all secrets immediately if they are ever exposed.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=IACM Crew Management
APP_VERSION=1.0.0
DEBUG=false

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_32_byte_hex_secret
JWT_SECRET_KEY=CHANGE_ME_generate_separate_32_byte_hex_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=CHANGE_ME_supabase_service_role_key

# ── Database (optional — used by SQLAlchemy/Alembic only) ─────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_password@db.YOUR_PROJECT_ID.supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres:CHANGE_ME_password@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production: HTTPS origins only, no localhost.
ALLOWED_HOSTS=["https://your-frontend-domain.com"]

# ── File uploads ─────────────────────────────────────────────────────────────
# NOTE: the code reads MAX_FILE_SIZE_MB (config.py) — keep this exact name.
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── Pagination ────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── FTL limits (EASA defaults — override per regulator) ───────────────────────
MAX_MONTHLY_HOURS=100.0
MAX_YEARLY_HOURS=900.0
MIN_REST_HOURS=10.0
MAX_DUTY_HOURS=14.0

# ── Push notifications (FCM) — optional ───────────────────────────────────────
# Path to the Firebase service-account JSON, OR the JSON inline. Keep the real
# file in backend/secrets/ (gitignored). Leave blank to run in STUB mode (no push).
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Redis (optional — rate-limit/cache backend) ───────────────────────────────
# Leave blank to use in-memory limiter. Set for multi-instance deployments.
REDIS_URL=

# ── Weather (CheckWX) ────────────────────────────────────────────────────────
# Optional. When set, /intelligence/weather uses CheckWX as the primary METAR
# source (richer parsed JSON, easier to display). Free tier: 300 calls/day —
# we cache 10 minutes per ICAO so multiple dashboards don't compound.
# Get a key at https://www.checkwxapi.com/ — leave blank to fall back to
# AviationWeather.gov (keyless, unlimited, raw METAR).
CHECKWX_API_KEY=

# ── Seed script (DEV ONLY) ────────────────────────────────────────────────────
# `python -m app.db.seed` refuses to run unless ALLOW_SEED=1 is set, and the
# seed user passwords are read from env (no static defaults — these are real
# logins). Pick strong, unique values per environment. NEVER set these in
# production — seed inserts an entire demo dataset.
ALLOW_SEED=
SEED_ADMIN_PASSWORD=
SEED_OPSMGR_PASSWORD=
SEED_SCHED_PASSWORD=
SEED_COMP_PASSWORD=
SEED_FLIGHTOPS_PASSWORD=
# Optional crew login accounts — left unset, the seed skips creating them
# (crew accounts are normally provisioned from the app's "login account" button).
SEED_CREW1_PASSWORD=
SEED_CREW2_PASSWORD=

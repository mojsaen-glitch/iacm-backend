{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/documents/cron/expiry-reminders",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/v1/assignments/cron/acceptance-reminders",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/v1/standby/cron/expire",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/v1/standby/cron/escalate",
      "schedule": "45 4 * * *"
    }
  ]
}
